{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "compilerOptions": {
            "rootDir": "src"
        },
        "include": [
            "src/"
        ],
        "lib": ["esnext"],
        "module": "commonjs",
        "moduleResolution": "node",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "lib",
        "sourceMap": true,
        "target": "esnext"
    },
    "exclude": ["node_modules"]
}
